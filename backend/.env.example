# ===========================================
# Reimburse AI Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# Application
APP_NAME=reimburseai-backend
APP_ENV=development
DEBUG=true
API_VERSION=v1
SECRET_KEY=your-super-secret-key-change-in-production

# Server
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Storage
STORAGE_BUCKET=receipts
MAX_FILE_SIZE_MB=10

# Blockchain (Avalanche Fuji Testnet)
AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
CHAIN_ID=43113

# x402 Protocol (Agent Communication)
AUDITOR_ENDPOINT=http://localhost:8001/api/auditor
AUDIT_FEE_USDC=0.05
X402_FACILITATOR_URL=https://x402.org/facilitator

# Thirdweb Engine (USDC Payouts)
# Get these from: https://thirdweb.com/dashboard/engine
THIRDWEB_ENGINE_URL=https://engine.thirdweb.com
THIRDWEB_SECRET_KEY=your-thirdweb-secret-key
THIRDWEB_COMPANY_WALLET_ADDRESS=0xYourCompanyWalletAddress
THIRDWEB_AGENT_A_WALLET_ADDRESS=0xYourAgentAWalletAddress

# Treasury Agent
TREASURY_SECRET_KEY=your-treasury-internal-secret-key

# OpenAI (GPT-4o for Receipt Auditing)
OPENAI_API_KEY=sk-your-openai-api-key

# Email (Resend) - Required for 2FA
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@yourdomain.com

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60






# .env - To deploy on Avalanche Mainnet:
# USE_MAINNET=true
# Automatically sets:
# - chain_id: 43114
# - chain_name: avalanche  
# - usdc_token_address: 0xB97EF9Ef8734C71904D8002F8b6Bc66Dd9c48a6E