# Reimburse AI Frontend Environment Variables
# =============================================

# Thirdweb Client ID (required for wallet connection)
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your-thirdweb-client-id

# API URL (defaults to localhost:8000)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Network (testnet or mainnet)
NEXT_PUBLIC_NETWORK=testnet

# Auditor wallet for x402 payments
NEXT_PUBLIC_AUDITOR_WALLET=0x2fAC7C9858e07eC8CaaAD17Ff358238BdC95dDeD
