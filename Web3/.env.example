# ReimburseAI Web3 Environment Variables
# Copy this file to .env and fill in the values

# ===========================================
# THIRDWEB CONFIGURATION
# ===========================================

# Your Thirdweb Client ID (for client-side usage)
# Get from: https://thirdweb.com/create-api-key
THIRDWEB_CLIENT_ID=

# Your Thirdweb Secret Key (for server-side usage) - NEVER expose this
THIRDWEB_SECRET_KEY=

# ===========================================
# NETWORK CONFIGURATION
# ===========================================

# Set to "true" for mainnet, "false" for testnet (Fuji)
USE_MAINNET=false

# Avalanche Fuji Testnet RPC URL
AVALANCHE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Avalanche Mainnet RPC URL (for production)
AVALANCHE_MAINNET_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# ===========================================
# SERVER WALLET CONFIGURATION
# ===========================================

# The identifier for the company server wallet (treasury)
# Used to create/access the main company wallet
SERVER_WALLET_IDENTIFIER=reimburseai-treasury

# The identifier for the auditor agent wallet
AUDITOR_WALLET_IDENTIFIER=reimburseai-auditor

# ===========================================
# USDC TOKEN ADDRESSES
# ===========================================

# Testnet USDC on Avalanche Fuji
USDC_TESTNET_ADDRESS=0x5425890298aed601595a70AB815c96711a31Bc65

# Mainnet USDC on Avalanche C-Chain
USDC_MAINNET_ADDRESS=0xB97EF9Ef8734C71904D8002F8b6Bc66Dd9c48a6E

# ===========================================
# VAULT FACTORY CONFIGURATION
# ===========================================

# Address of deployed Vault Factory contract (set after deployment)
VAULT_FACTORY_ADDRESS=

# Default gas limit for vault deployment
VAULT_DEPLOYMENT_GAS_LIMIT=500000

# ===========================================
# API CONFIGURATION (for backend integration)
# ===========================================

# Backend API URL for webhook notifications
BACKEND_API_URL=http://localhost:8000

# API key for backend communication
BACKEND_API_KEY=

# ===========================================
# MONITORING & DEBUGGING
# ===========================================

# Enable verbose logging for development
DEBUG_MODE=true

# Transaction confirmation timeout (in ms)
TX_CONFIRMATION_TIMEOUT=60000

# Maximum retry attempts for failed transactions
MAX_TX_RETRIES=3
